{
  "name": "polkame-backend",
  "version": "2.0.0",
  "type": "module",
  "description": "PolkaMe on-chain backend — Express API + Hardhat EVM contracts",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "node:local": "npx hardhat node",
    "compile": "npx hardhat compile",
    "deploy:local": "npx hardhat run scripts/deploy.ts --network localhost",
    "test:contracts": "npx hardhat test --network localhost",
    "seed:local": "npx hardhat run scripts/seed.ts --network localhost",
    "fund:local": "npx hardhat run scripts/fund.ts --network localhost"
  },
  "dependencies": {
    "@polkadot/util": "^12.6.2",
    "@polkadot/util-crypto": "^12.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "thirdweb": "^5.119.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/chai": "^5.2.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.12.2",
    "@types/uuid": "^9.0.8",
    "chai": "^6.2.2",
    "hardhat": "^3.1.10",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  }
}
