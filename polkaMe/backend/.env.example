# ===================================================================
# PolkaMe Backend Environment (On-Chain Mode)
# ===================================================================
#
# Deploy contracts from THIS directory:
#   npm run node:local    (terminal 1 — keep running)
#   npm run deploy:local  (terminal 2 — copy addresses below)
#
# ---------------------------- Server --------------------------------
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ----------------------------- Auth ---------------------------------
# Generate a secure value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_32_plus_char_random_secret
JWT_EXPIRES_IN=7d

# false = dev-friendly (protected routes allow requests without JWT)
# true  = production (JWT required on protected routes)
REQUIRE_AUTH=false

# Optional for EVM login flow (thirdweb). Polkadot auth works without this.
THIRDWEB_SECRET_KEY=
AUTH_DOMAIN=localhost

# --------------------------- Blockchain -----------------------------
# Local Hardhat RPC (default)
RPC_URL=http://127.0.0.1:8545

# Fill after deploy:
# npx hardhat run scripts/deploy.ts --network localhost
IDENTITY_CONTRACT_ADDRESS=0x
ACCOUNTS_CONTRACT_ADDRESS=0x
GOVERNANCE_CONTRACT_ADDRESS=0x
SECURITY_CONTRACT_ADDRESS=0x

# Backend signer used for server-submitted writes
# Local dev: use Hardhat Account #0 private key
# Never use a publicly known key on live networks.
BACKEND_WALLET_KEY=0x
